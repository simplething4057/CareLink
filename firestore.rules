rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Fields: uid, email, displayName, photoURL, profile, createdAt
    //
    // Collection: health_reports
    // Fields: id, uid, date, overallScore, summary, metrics, actionPlan, createdAt
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    // User Profile Rules
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(uid) && request.resource.data.uid == resource.data.uid;
    }

    // Health Reports Rules
    match /health_reports/{reportId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isDocOwner() && request.resource.data.uid == resource.data.uid;
      allow delete: if isDocOwner();
    }
  }
}
